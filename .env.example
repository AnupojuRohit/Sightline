SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
# Slack app client ID used for the user-token OAuth flow.
SLACK_CLIENT_ID=
# Slack app client secret used to exchange the OAuth code.
SLACK_CLIENT_SECRET=
# Public redirect URI registered in Slack for /slack/oauth/callback.
# Local default: http://127.0.0.1:5001/slack/oauth/callback
SLACK_OAUTH_REDIRECT_URI=
# Local file path for persisted OAuth user tokens (keep out of git).
SIGHTLINE_TOKEN_STORE_PATH=.token_store.json
# GitHub token used for live issue/PR state lookups.
GITHUB_TOKEN=
# Short TTL cache for GitHub API responses to avoid rate-limit spikes during demos.
GITHUB_CACHE_TTL_SECONDS=180
# Required Slack user OAuth scopes for RTS live search:
# - search:read
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LOG_LEVEL=INFO
SLACK_AUTH_TEST_ON_STARTUP=false
SIGHTLINE_USE_MOCK_LISTS=false
SIGHTLINE_ENABLE_LIST_UPDATES=false
SIGHTLINE_ENABLE_AI_EXPLANATIONS=false
# Optional default Slack List ID used by the real dashboard Run Scan button.
SIGHTLINE_DEFAULT_LIST_ID=
